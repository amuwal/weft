# ── Linger · .gitignore ───────────────────────────────────────
# Source of truth. Anything not explicitly listed is committed.

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# Xcode — user-specific
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata/
*.xcscmblueprint
*.xccheckout

# Xcode — build products
build/
DerivedData/
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Xcode — generated by XcodeGen
# We commit project.yml; .xcodeproj is regenerated. Comment out the next line
# if you'd rather commit the .xcodeproj (e.g. CI without xcodegen).
*.xcodeproj

# Swift Package Manager
.build/
.swiftpm/
Packages/
Package.pins
Package.resolved

# CocoaPods / Carthage — we don't use them, but pre-empt the temptation
Pods/
Carthage/Build/
Carthage/Checkouts/

# fastlane (we use Xcode Cloud, but if anyone runs fastlane locally:)
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# Secrets / env
.env
.env.*
!.env.example
*.p8
*.p12
AuthKey_*.p8

# Editor / OS
*.swp
*.swo
.idea/
.vscode/
*.suo
*.user

# Coverage / test reports
*.gcno
*.gcda
coverage/
.test-results/

# OS-level
Thumbs.db
desktop.ini

# Tool-managed
.mint/
.tuist-version
.tool-versions

# Local screenshots / scratch
/tmp/
/screenshots/
*.png.scratch

# Internal-only — not for the public repo
.agents/
CLAUDE.md
HANDOFF.md
design/
memory/
research/
skills-lock.json
spec/

# Marketing / demo PNGs at repo root
/hero.png
/final-light-dark.png
/screenshots-all.png
/screenshots-dark.png
/screenshots-v0.1.png
/screenshots-v0.2.png
/screenshots-v0.3.png
